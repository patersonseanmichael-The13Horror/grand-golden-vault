<!DOCTYPE html>
<html>
<head>
  <title>Golden Vault — Lobby</title>
  <link rel="stylesheet" href="/vault/vaultTheme.css">
</head>
<body>

<div class="vault-panel">
  <h2>Private Vault Overview</h2>

  <p><strong>Balance:</strong> <span id="balance"></span></p>

  <button onclick="deposit()">Deposit 100 GOLD</button>
  <button onclick="logout()">Logout</button>

  <h3 style="margin-top:32px;">Available Games</h3>

  <div class="vault-grid">
    <div class="vault-tile" onclick="locked()">
      <h3>Blackjack</h3>
      <p>Institutional table play</p>
    </div>

    <div class="vault-tile" onclick="locked()">
      <h3>Roulette</h3>
      <p>European wheel</p>
    </div>

    <div class="vault-tile" onclick="locked()">
      <h3>Slots</h3>
      <p>High-limit reels</p>
    </div>

    <div class="vault-tile" onclick="locked()">
      <h3>Poker</h3>
      <p>Private tables</p>
    </div>
  </div>

  <h3 style="margin-top:32px;">Ledger</h3>
  <ul id="ledger"></ul>
</div>

<script src="/vault/vaultRouter.js"></script>
<script src="/vault/vaultAuth.js"></script>
<script src="/vault/vaultEngine.js"></script>

<script>
VaultAuth.enforce();

function render(){
  document.getElementById("balance").textContent =
    VaultEngine.getBalance() + " GOLD";

  const ledger = document.getElementById("ledger");
  ledger.innerHTML = "";

  VaultEngine.getLedger().forEach(tx=>{
    const li = document.createElement("li");
    li.textContent = `${tx.type} — ${tx.amount} — ${tx.timestamp}`;
    ledger.appendChild(li);
  });
}

function deposit(){
  VaultEngine.deposit(100, "PHASE_B_TEST");
  render();
}

function logout(){
  VaultRouter.logout();
}

function locked(){
  alert("Access restricted. This game is not yet available.");
}

render();
</script>

</body>
</html>
